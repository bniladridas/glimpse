{
  "name": "glimpse",
  "private": true,
  "version": "0.0.0",
  "description": "A logo builder and background isolation tool.",
  "author": "Niladri Das",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "desktop:dev": "vite build --base=./ && electron .",
    "desktop:dmg": "vite build --base=./ && electron-builder --mac dmg",
    "android:sync": "vite build --base=./ && cap sync android",
    "android:open": "cap open android",
    "android:apk": "vite build --base=./ && cap sync android && cd android && ./gradlew assembleDebug",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.niladridas.glimpse",
    "productName": "Glimpse",
    "directories": {
      "output": "release"
    },
    "afterPack": "electron/after-pack.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.png",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": "dmg",
      "identity": null,
      "icon": "assets/icon.png"
    },
    "protocols": [
      {
        "name": "Glimpse Auth",
        "schemes": [
          "glimpse"
        ]
      }
    ]
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.4",
    "@imgly/background-removal": "^1.7.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
